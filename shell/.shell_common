# ---------------------------------------------------------
# Shared shell config — sourced by both .zshrc and .bashrc
# ---------------------------------------------------------

# ---------------------------------------------------------
# Environment & Pathing
# ---------------------------------------------------------
[ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"

if [ "$(uname)" = "Darwin" ]; then
    if [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
fi

# ---------------------------------------------------------
# Editor
# ---------------------------------------------------------
if command -v nvim > /dev/null 2>&1; then
    alias vim="nvim"
    alias vi="nvim"
    export EDITOR="nvim"
    export VISUAL="nvim"
fi

# ---------------------------------------------------------
# Aliases
# ---------------------------------------------------------
if command -v fdfind > /dev/null 2>&1; then alias fd='fdfind'; fi

alias ..="cd .."
alias ...="cd ../.."
if [ "$(uname)" = "Darwin" ]; then
    alias ls="ls -G"
else
    alias ls="ls --color=auto"
fi

# ---------------------------------------------------------
# Prompt
# ---------------------------------------------------------
if [ -z "$TMUX" ]; then
    export TERM="xterm-256color"
fi

# ---------------------------------------------------------
# Zoxide
# ---------------------------------------------------------
if command -v zoxide > /dev/null 2>&1; then
    _shell_name=$(basename "$SHELL")
    eval "$(zoxide init "$_shell_name" --cmd cd)"
    unset _shell_name
fi

# Fuzzy Jump (zoxide + fzf)
fj() {
    local dir
    dir=$(zoxide query -l | fzf --height 40% --layout=reverse --border --preview 'ls -F -G {1}') && cd "$dir"
}

# ---------------------------------------------------------
# FZF
# ---------------------------------------------------------
if command -v fzf > /dev/null 2>&1; then
    [ -f ~/.fzf.bash ] && . ~/.fzf.bash
    [ -f ~/.fzf.zsh ] && . ~/.fzf.zsh
    [ -f /usr/share/doc/fzf/examples/key-bindings.bash ] && . /usr/share/doc/fzf/examples/key-bindings.bash
    [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && . /usr/share/doc/fzf/examples/key-bindings.zsh
    [ -f /usr/share/doc/fzf/examples/completion.bash ] && . /usr/share/doc/fzf/examples/completion.bash
    [ -f /usr/share/doc/fzf/examples/completion.zsh ] && . /usr/share/doc/fzf/examples/completion.zsh
    if [ "$(uname)" = "Darwin" ] && command -v brew > /dev/null 2>&1; then
        _brew_prefix="$(brew --prefix)"
        [ -f "$_brew_prefix/opt/fzf/shell/key-bindings.bash" ] && . "$_brew_prefix/opt/fzf/shell/key-bindings.bash"
        [ -f "$_brew_prefix/opt/fzf/shell/key-bindings.zsh" ] && . "$_brew_prefix/opt/fzf/shell/key-bindings.zsh"
        unset _brew_prefix
    fi
    export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border --color=16"
fi
