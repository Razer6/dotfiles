# ---------------------------------------------------------
# Shared shell config — sourced by both .zshrc and .bashrc
# ---------------------------------------------------------

# ---------------------------------------------------------
# Environment & Pathing
# ---------------------------------------------------------
[ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"

if [ "$(uname)" = "Darwin" ]; then
    if [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
fi

# ---------------------------------------------------------
# Editor
# ---------------------------------------------------------
if command -v nvim > /dev/null 2>&1; then
    alias vim="nvim"
    alias vi="nvim"
    export EDITOR="nvim"
    export VISUAL="nvim"
fi

# ---------------------------------------------------------
# Aliases
# ---------------------------------------------------------
if command -v fdfind > /dev/null 2>&1; then alias fd='fdfind'; fi

alias ..="cd .."
alias ...="cd ../.."
if [ "$(uname)" = "Darwin" ]; then
    alias ls="ls -G"
else
    alias ls="ls --color=auto"
fi

# ---------------------------------------------------------
# Prompt
# ---------------------------------------------------------
if [ -z "$TMUX" ]; then
    export TERM="xterm-256color"
fi

# ---------------------------------------------------------
# FZF
# ---------------------------------------------------------
if command -v fzf > /dev/null 2>&1; then
    export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border --color=16"

    _fzf_shell="${ZSH_VERSION:+zsh}"
    _fzf_shell="${_fzf_shell:-bash}"

    # Modern fzf (0.48+) has built-in shell integration
    if fzf --"$_fzf_shell" > /dev/null 2>&1; then
        eval "$(fzf --"$_fzf_shell")"
    else
        # Fall back to sourcing shell files from known paths
        for _fzf_dir in \
            "$HOME/.fzf" \
            "/usr/share/doc/fzf/examples" \
            "/usr/share/fzf/shell" \
            "/usr/share/fzf" \
            "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/fzf/shell"; do
            [ -f "$_fzf_dir/key-bindings.$_fzf_shell" ] && . "$_fzf_dir/key-bindings.$_fzf_shell"
            [ -f "$_fzf_dir/completion.$_fzf_shell" ] && . "$_fzf_dir/completion.$_fzf_shell"
        done
        [ -f "$HOME/.fzf.$_fzf_shell" ] && . "$HOME/.fzf.$_fzf_shell"
    fi

    unset _fzf_shell _fzf_dir
fi

# ---------------------------------------------------------
# Zoxide (must be last to avoid cd override conflicts)
# ---------------------------------------------------------
if command -v zoxide > /dev/null 2>&1; then
    _shell_name="${ZSH_VERSION:+zsh}"
    _shell_name="${_shell_name:-bash}"
    eval "$(zoxide init "$_shell_name")"
    unset _shell_name
fi

# Fuzzy Jump (zoxide + fzf)
fj() {
    local dir
    dir=$(zoxide query -l | fzf --height 40% --layout=reverse --border --preview 'ls -F -G {1}') && cd "$dir"
}
